local function createSnow()
    local snow = Instance.new("Frame", frame)
    snow.Size = UDim2.new(0, 3, 0, 3)
    snow.BackgroundColor3 = Color3.new(1, 1, 1)
    snow.BackgroundTransparency = 0.4
    snow.Position = UDim2.new(math.random(), 0, -0.1, 0)
    Instance.new("UICorner", snow).CornerRadius = UDim.new(1, 0)
    task.spawn(function()
        local fallSpeed = math.random(2, 5) / 1000
        while snow.Parent and snow.Position.Y.Scale < 1.1 do
            if snow.Parent then snow.Position = snow.Position + UDim2.new(0, 0, fallSpeed, 0) end
            RunService.RenderStepped:Wait()
        end
        snow:Destroy()
    end)
end
task.spawn(function() while task.wait(0.3) do if frame.Visible then createSnow() end end end)

